

CREATE FILTER MODULE FilterNode_Filter
	CREATE FUNCTION Main() RETURNS BOOLEAN
	BEGIN
		
		
		DECLARE inref REFERENCE TO Root.XMLNSC.[<];
		IF FIELDNAME(Root.XMLNSC.[<]) = 'student' THEN
			RETURN TRUE;
		ELSEIF FIELDNAME(Root.XMLNSC.[<]) = 'employee' THEN
			RETURN FALSE;
		ELSE
			RETURN UNKNOWN;
		END IF;
		
		RETURN FALSE;
	END;

END MODULE;
