{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "type": "object",
  "required": ["Name", "id", "dept", "phone", "address"],
  "properties": {
    "Name": {
      "type": "string",
      "minLength": 1
    },
    "id": {
      "type": "integer"
    },
    "dept": {
      "type": "string"
    },
    "phone": {
      "type": "integer"
    },
    "address": {
      "type": "string"
    }
  },
  "additionalProperties": false
}