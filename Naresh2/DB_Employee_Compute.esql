

CREATE COMPUTE MODULE DB_Employee_Compute
	CREATE FUNCTION Main() RETURNS BOOLEAN
	BEGIN
		 CALL CopyMessageHeaders();
		-- CALL CopyEntireMessage();
--		DECLARE id INTEGER;
--		DECLARE EmpName CHARACTER;
