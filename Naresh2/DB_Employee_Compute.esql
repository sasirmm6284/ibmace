--		DECLARE Company CHARACTER;
		
--		INSERT INTO Database.DB_DSN.naresh.employee1 (id,EmpName,Salary,Company) VALUES (1,'Naresh',100,'NMIT');
--		INSERT INTO Database.DB_DSN.naresh.employee1 (id,EmpName,Salary,Company) VALUES (1,'Suresh',100,'NMIT');
--		INSERT INTO Database.DB_DSN.naresh.employee1 (id,EmpName,Salary,Company) VALUES (1,'Mahesh',100,'NMIT');
